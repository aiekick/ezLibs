	cd /home/runner/work/ezLibs/ezLibs/build_linux_release && $(MAKE) $(MAKESILENT) -f Tests/TestMisc/CMakeFiles/EzLibs_TestMisc.dir/build.make Tests/TestMisc/CMakeFiles/EzLibs_TestMisc.dir/main.cpp.i
.PHONY : main.cpp.i

main.s: main.cpp.s
.PHONY : main.s

# target to generate assembly for a file
main.cpp.s:
	cd /home/runner/work/ezLibs/ezLibs/build_linux_release && $(MAKE) $(MAKESILENT) -f Tests/TestMisc/CMakeFiles/EzLibs_TestMisc.dir/build.make Tests/TestMisc/CMakeFiles/EzLibs_TestMisc.dir/main.cpp.s
.PHONY : main.cpp.s

